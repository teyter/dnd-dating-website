<!DOCTYPE html>
<html>
<head>
  <title>Error</title>
  <link rel='stylesheet' href='/stylesheets/error.css' />
  <link href="https://fonts.googleapis.com/css2?family=Abril+Fatface&family=Lato:wght@400;700;900&family=Aladin&display=swap" rel="stylesheet">
</head>

  <!-- 404 Error Page -->
<body>
  <% const status = statusCode || 500; %>
  <% if (status === 404) { %>
    <div class="top">
      <h1>404</h1>
      <h3>page not found</h3>
    </div>
    <div class="container">
      <div class="ghost-copy">
        <div class="one"></div>
        <div class="two"></div>
        <div class="three"></div>
        <div class="four"></div>
      </div>
      <div class="ghost">
        <div class="face">
          <div class="ghost-eye"></div>
          <div class="ghost-eye-right"></div>
          <div class="mouth"></div>
        </div>
      </div>
      <div class="shadow"></div>
    </div>
    <div class="bottom">
      <p>Boo, looks like a ghost stole this page!</p>
      <div class="buttons">
        <a href="/" class="btn">Home</a>
      </div>
    </div>
  <% } else if (status === 403) { %>

    <!-- 403 Error Page - Gandalf "You Shall Not Pass" -->
    <div class="error-403">
      <div class="gandalf-container">
        <div class="gandalf-body">
          <div class="gandalf-moustache"></div>
          <div class="gandalf-beard"></div>
        </div>
        <div class="gandalf-feet"></div>
        <div class="gandalf-hand-left"></div>
        <div class="gandalf-hand-right"></div>
        <div class="sword"></div>
        <div class="spear"></div>
        <div class="spear-head"></div>
        <div class="message">
          <h2>You Shall Not Pass</h2>
          <p>403 Forbidden</p>
          <a href="/" class="btn">Home</a>
        </div>
      </div>
    </div>
  <% } else if (status === 500) { %>

    <!-- 500 Error Page -->
    <div class="error-500">
      <div class="error-content">
        <div class="five-zero">
          <span class="error-num">5</span>
          <div class="eye-container">
            <div class="eye"></div>
            <div class="eye"></div>
          </div>
        </div>
        <p class="sub-text">Oh eyeballs! Something went wrong. We're <i>looking</i> to see what happened.</p>
        <a href="/" class="btn">Go back</a>
      </div>
    </div>
  <% } else { %>

    <!-- Generic Error Page -->
    <div class="error-generic">
      <h1>Oops! Something went wrong</h1>
      <p>We're sorry, but an unexpected error occurred.</p>
      <div class="buttons">
        <a href="javascript:history.back()" class="btn">Back</a>
        <a href="/" class="btn">Home</a>
      </div>
    </div>
  <% } %>

  <script src="/js/error.js"></script>
</body>
</html>
