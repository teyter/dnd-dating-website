<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Monitoring</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/admin.css' />
</head>
<body>
    <nav class="main-menu">
        <div>
            <div class="nav-text">D&D Dating</div>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/admin">Admin</a></li>
                <li><a href="/users">Users</a></li>
            </ul>
        </div>
        <div class="logout">
          <% if (locals.user) { %>
            <form method="POST" action="/logout">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit">Logout (<%= locals.user.name %>)</button>
            </form>
          <% } else { %>
            <a href="/login" class="button">Login</a>
            <a href="/register" class="button">Register</a>
          <% } %>
        </div>
    </nav>

    <div class="content">
        <h2>Admin Dashboard</h2>

        <a href="/" class="back-link">← Back to Home</a>

        <div class="admin-stats-grid">
            <div class="stat-card green">
                <div class="stat-value"><%= totalUsers %></div>
                <div class="stat-label">Total Accounts</div>
            </div>
            <div class="stat-card teal">
                <div class="stat-value"><%= totalProfiles %></div>
                <div class="stat-label">Profiles Created</div>
            </div>
            <div class="stat-card blue">
                <div class="stat-value"><%= totalMessages %></div>
                <div class="stat-label">Total Messages</div>
            </div>
            <div class="stat-card cyan">
                <div class="stat-value"><%= todayMessages %></div>
                <div class="stat-label">Messages Today</div>
            </div>
            <div class="stat-card purple">
                <div class="stat-value"><%= totalPageViews %></div>
                <div class="stat-label">Total Page Views</div>
            </div>
            <div class="stat-card magenta">
                <div class="stat-value"><%= todayPageViews %></div>
                <div class="stat-label">Page Views Today</div>
            </div>
            <div class="stat-card orange">
                <div class="stat-value"><%= activeUsers %></div>
                <div class="stat-label">Active Users (24h)</div>
            </div>
            <div class="stat-card yellow">
                <div class="stat-value"><%= Math.round(appUptimeSeconds) %>s</div>
                <div class="stat-label">App Uptime</div>
            </div>
            <div class="stat-card red">
                <div class="stat-value"><%= Math.round(memory.rss / 1024 / 1024) %> MB</div>
                <div class="stat-label">Memory Usage</div>
            </div>
        </div>

        <!-- Our real time activity feed -->
        <div class="admin-panel admin-panel-margin-top">
            <h3>Real-Time Activity Feed</h3>
            <div class="activity-feed">
                <% if (recentActivity && recentActivity.length > 0) { %>
                    <% recentActivity.forEach(function(activity) { %>
                        <div class="activity-item">
                            <span class="activity-time"><%= new Date(activity.viewed_at).toLocaleString() %></span>
                            <span class="activity-page"><%= activity.page_name %></span>
                            <% if (activity.user_name) { %>
                                <span class="activity-user"><%= activity.user_name %></span>
                            <% } else { %>
                                <span class="activity-guest">guest</span>
                            <% } %>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="no-activity-message">
                        No recent activity yet<br>
                        <small>Activity will appear here as users browse the site</small>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Server Info and Security Log -->
        <div class="two-column">
            <div class="admin-panel">
                <h3>Server Info</h3>
                <div class="server-output">
                    <div><strong>System Uptime:</strong> <%= Math.round(systemUptimeSeconds / 60) %> minutes</div>
                    <div><strong>Heap Used:</strong> <%= Math.round(memory.heapUsed / 1024 / 1024) %> MB</div>
                </div>
                
                <div class="admin-panel-margin-top-sm">
                    <strong>Shell Output:</strong>
                    <div class="uptime-output">
                        <%= uptimeOut %>
                    </div>
                </div>
                
                <h3 class="warning admin-panel-margin-top-sm">Write Log Entry</h3>
                <form method="POST" action="/admin/log" class="log-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input name="message" placeholder="Enter log message..." />
                    <button type="submit">Write</button>
                </form>
            </div>

            <!-- Security Log -->
            <div class="admin-panel">
                <h3>Security Log</h3>
                <pre class="log-panel"><%= securityLogTail %></pre>
            </div>
        </div>

        <!-- Recent Log -->
        <div class="admin-panel admin-panel-margin-top-sm">
            <h3>Recent Log</h3>
            <pre class="log-panel"><%= logTail %></pre>
        </div>
    </div>
</body>
</html>
