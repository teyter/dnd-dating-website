<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create User</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
    <nav class="main-menu">
        <div>
            <div class="nav-text">D&D Dating</div>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/admin">Admin</a></li>
                <li><a href="/users">Users</a></li>
            </ul>
        </div>
        <div class="logout">
          <% if (locals.user) { %>
            <form method="POST" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit">Logout (<%= locals.user.name %>)</button>
            </form>
          <% } else { %>
            <a href="/login" class="button">Login</a>
            <a href="/register" class="button">Register</a>
          <% } %>
        </div>
    </nav>

    <div class="content">
        <h2>Create New User</h2>

        <a href="/users" class="back-link">← Back to Users</a>

        <div class="profile-container" style="flex-direction: column;">
            <form method="POST" action="/users/new">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="form-group">
                    <label>Username:</label>
                    <input name="name" required />
                </div>
                <div class="form-group">
                    <label>Password:</label>
                    <input name="pass" type="password" required />
                </div>
                <div class="form-group">
                    <label>User Type:</label>
                    <select name="userType">
                        <option value="player">Player</option>
                        <option value="dm">DM (Dungeon Master)</option>
                        <option value="both">Both</option>
                    </select>
                </div>
                <button type="submit">Create User</button>
            </form>
        </div>
    </div>
</body>
</html>
