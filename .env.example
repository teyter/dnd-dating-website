# Production Environment Variables
# Copy this to .env and fill in the values

# REQUIRED: Session secret for cookie signing (generate a long random string)
SESSION_SECRET=your-super-long-random-secret-here-min-32-chars

# REQUIRED: Admin username (used to determine admin privileges)
ADMIN_USERNAME=TheBoss

# Optional: Node environment (set to 'production' for production)
NODE_ENV=production

# Optional: Port (default: 3000)
# PORT=3000

# Optional: Host (default: 0.0.0.0)
# HOST=127.0.0.1